# ── MQTT ──────────────────────────────────────────────────────
# Production: suts-fyp-floodwatch-mqtt.fly.dev
# Local dev:  mosquitto  (docker-compose service name)
MQTT_BROKER=suts-fyp-floodwatch-mqtt.fly.dev
MQTT_PORT=1883

# ── MongoDB ───────────────────────────────────────────────────
# Atlas (staging/prod): mongodb+srv://user:pass@cluster.mongodb.net/
# Local dev:            mongodb://mongo:27017
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB=flood_monitor
MONGO_COL=sensor_readings

# ── Redis (internal event bus) ────────────────────────────────
# Redis runs on the DigitalOcean droplet (same server as the API).
# The EC2 parser and any other service connect to it remotely.
#
# Local dev:    redis://redis:6379          (docker-compose service name)
# Staging/prod: redis://:password@DO_IP:6379
#
# REDIS_PASSWORD must match the --requirepass value Redis is started with.
# Both deploy-parser.yml and deploy-api.yml read REDIS_URL from GitHub Secrets.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-me-to-something-secret

# ── Parser config ─────────────────────────────────────────────
# Seconds without a heartbeat before a node is marked offline (health checker)
# Match to NODE_OFFLINE_TIMEOUT_MS in firmware (production: 180s, testing: 60s)
NODE_OFFLINE_TIMEOUT=60
# Seconds to suppress duplicate alerts of the same type from the same node
# Firmware retries every 5s until ACKed — this prevents MQTT retries spamming the DB
ALERT_DEDUP_WINDOW=60
# Max entries in the in-memory alert dedup cache (LRU eviction when full)
# At 50000 entries × ~120 bytes each ≈ 6MB. Increase for country-scale deployments.
ALERT_DEDUP_MAX=50000
# MQTT shared subscription group name — all parser instances with the same group
# receive each message exactly once (round-robin). Scale by adding EC2 instances.
MQTT_SHARE_GROUP=parsers
# Number of worker threads processing MQTT messages in parallel
# Each thread handles one message at a time; shared state is lock-protected
WORKER_THREADS=4
