# ── MQTT ──────────────────────────────────────────────────────
# Production: suts-fyp-floodwatch-mqtt.fly.dev
# Local dev:  mosquitto  (docker-compose service name)
MQTT_BROKER=suts-fyp-floodwatch-mqtt.fly.dev
MQTT_PORT=1883

# ── MongoDB ───────────────────────────────────────────────────
# Atlas (staging/prod): mongodb+srv://user:pass@cluster.mongodb.net/
# Local dev:            mongodb://mongo:27017
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_DB=flood_monitor
MONGO_COL=sensor_readings

# ── Redis (internal event bus) ────────────────────────────────
# Redis runs on the DigitalOcean droplet (same server as the API).
# The EC2 parser and any other service connect to it remotely.
#
# Local dev:    redis://redis:6379          (docker-compose service name)
# Staging/prod: redis://:password@DO_IP:6379
#
# REDIS_PASSWORD must match the --requirepass value Redis is started with.
# Both deploy-parser.yml and deploy-api.yml read REDIS_URL from GitHub Secrets.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-me-to-something-secret

# ── Parser config ─────────────────────────────────────────────
# Voltage below this triggers a battery_low SSE event (12V system)
BATTERY_LOW_V=11.5
# Comma-separated node IDs with no float sensors (black nodes)
NODES_WITHOUT_FLOAT=SUTS_Black
